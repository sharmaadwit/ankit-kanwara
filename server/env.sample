PORT=8080
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
FORCE_REMOTE_STORAGE=true
FORCE_PG_SSL=true

# Optional: DB pool tuning (conservative defaults for free/shared plans).
# PGPOOL_MAX=5
# PGPOOL_IDLE_TIMEOUT_MS=30000
# PGPOOL_CONNECTION_TIMEOUT_MS=5000

# Optional: hot-read storage cache TTL in milliseconds (default 3000).
# STORAGE_READ_CACHE_TTL_MS=3000

# Optional fallbacks when DATABASE_URL is not provided
PGUSER=postgres
PGPASSWORD=changeme
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=postgres

# Railway-specific helpers (optional)
RAILWAY_PRIVATE_DOMAIN=
RAILWAY_TCP_PROXY_DOMAIN=
RAILWAY_TCP_PROXY_PORT=

# Security and integration controls
CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
APP_PUBLIC_URL=https://app-example.up.railway.app
STORAGE_API_KEY=super-secret-key
# Optional: require API key for pricing-calc integration (POST/GET /api/pricing-calculations). If unset, falls back to STORAGE_API_KEY.
# PRICING_CALC_API_KEY=your-pricing-calc-api-key
# Optional: require X-Api-Key for pricing-calc integration (POST/GET). If unset, PRICING_CALC_API_KEY falls back to STORAGE_API_KEY.
# PRICING_CALC_API_KEY=

# Phase 3 server-side auth (cookie-first with header fallback)
# SESSION_COOKIE_NAME=pams_sid
# SESSION_TTL_SEC=86400
# FORCE_COOKIE_AUTH=true   # When true, /api/config returns cookieAuth: true and client uses POST /api/auth/login + session cookie; header/API-key still work as fallback

# Local testing only: allow login without DB (username: dev, password: dev). Never used in production (NODE_ENV=production).
# ALLOW_DEV_LOGIN=true

# Rate limiting (requests per 15 minutes per IP)
# RATE_LIMIT_STORAGE_MAX=150
# RATE_LIMIT_ADMIN_MAX=100

# Gmail API (OAuth 2.0) configuration
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=notifications@example.com

# Logging: LOG_LEVEL=error|warn|info (default). Only events at or above this level are logged.
# LOG_LEVEL=warn
# Health-check requests (GET /api/health) are not logged to reduce noise.
# Optional log forwarding
RAILWAY_LOGS_ENDPOINT=
RAILWAY_LOGS_TOKEN=

# Data optimisation (D-002): normalized tables behind feature flag
# Set NORMALIZED_TABLES_ENABLED=true to create accounts/projects/activities/internal_activities tables and enable dual-write from storage. Default: off.
# NORMALIZED_TABLES_ENABLED=true
# activity_submission_logs table is always created (audit). Optional backfill when flag is on:
#   npm run backfill-normalized-dry   # dry run
#   npm run backfill-normalized       # apply
# READ_FROM_NORMALIZED_TABLES=true is reserved for future read-path cutover (not implemented yet).

# Daily backup (export-storage-snapshot.js / cron / GitHub Actions)
REMOTE_STORAGE_BASE=https://your-app.up.railway.app/api/storage
REMOTE_STORAGE_USER=
REMOTE_STORAGE_HEADERS=
SNAPSHOT_DIR=
SNAPSHOT_FILE=
